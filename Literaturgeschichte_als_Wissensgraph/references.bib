@article{rebora_is_2018-1,
	title = {Is “{Late} {Style}” measurable? {A} stylometric analysis of {Johann} {Wolfgang} {Goethe}’s, {Robert} {Musil}’s, and {Franz} {Kafka}’s late works},
	copyright = {Copyright (c) 2023 Elephant \& Castle},
	issn = {1826-6118},
	shorttitle = {Is “{Late} {Style}” measurable?},
	url = {https://elephantandcastle.unibg.it/index.php/eac/article/view/392},
	abstract = {Since the studies of Adorno, Broch, and Benn, the “late” condition of artistic creation has always been described in terms of an evident stylistic fracture. However, recent theorizations tend to evaluate it as nothing but “a critical and ideological construct” (McMullan, Smiles). With our contribution, we will test these theorizations with the computational methods of stylometry, that are generally used for authorship attribution and distant reading, and that proved to be very sensitive to the temporal component. By using the Kolimo corpus and the Stylo software, we will perform a series of broad-spectrum experiments on authors of modern German literature (Robert Musil, Franz Kafka), verifying for which authors a caesura is present on the chronological line, and if this corresponds –\&nbsp;according to the intuition by Said –\&nbsp;with an increased distance from contemporary authors. Special attention will be devoted to the case study of Goethe and to how stylometry imposes a re-questioning of the traditional concept of style.},
	language = {it},
	number = {18},
	urldate = {2025-02-18},
	journal = {Elephant \& Castle},
	author = {Rebora, Simone and Salgaro, Massimo},
	month = nov,
	year = {2018},
	note = {Number: 18},
	keywords = {THESIS},
}

@article{rotari_grimm_2021,
	title = {The {Grimm} {Brothers}: {A} stylometric network analysis},
	volume = {36},
	issn = {2055-7671},
	shorttitle = {The {Grimm} {Brothers}},
	url = {https://doi.org/10.1093/llc/fqz088},
	doi = {10.1093/llc/fqz088},
	abstract = {Stylometric methods can be used to reveal similarities between texts and, combined with network analysis, to depict the stylistic relations between those texts. The research conducted here focuses on a corpus of letters written by Jacob and Wilhelm Grimm. Using stylometric analysis, we model the writing styles of the brothers depending on the addressees and chronology. The brothers have individual styles: Wilhelm has a more friendly and personal tone independent on addresses, while Jacob has a more impersonal style, unless he was writing to Wilhelm. Their styles merge at the interactions of their career or personal development.},
	number = {1},
	urldate = {2025-02-18},
	journal = {Digital Scholarship in the Humanities},
	author = {Rotari, Gabriela and Jander, Melina and Rybicki, Jan},
